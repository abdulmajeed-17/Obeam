# Copy this file to .env and fill in your values.
# Get a free Postgres URL from https://neon.tech or https://railway.app

DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=your-secret-at-least-32-chars
CORS_ORIGIN=http://localhost:5173
PORT=3000

# Live FX feed (optional). Get a key at https://www.exchangerate-api.com/
# FX_FEED_API_KEY=your_key
# Optional: secret for GET /fx/sync (cron). If set, send header X-Fx-Sync-Secret.
# FX_SYNC_SECRET=

# Admin panel — list transfers, mark processing/settled/failed. Send header X-Admin-Secret.
ADMIN_SECRET=your-admin-secret

# Encryption key for sensitive data (KYB documents, etc.)
ENCRYPTION_KEY=obeam-dev-encryption-key-change-in-production

# Email (welcome, money received, etc.) via Resend — https://resend.com
# 1. Sign up at resend.com
# 2. Add & verify your domain (Dashboard → Domains)
# 3. Create API key (Dashboard → API Keys)
# 4. Add both below to Railway
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=Obeam <noreply@yourdomain.com>

# ─── Paystack (deposits & withdrawals) ─────────────────────────────────
# Get keys at https://dashboard.paystack.com/#/settings/developers
# Test keys start with sk_test_ / pk_test_ — free, no real money
# PAYSTACK_SECRET_KEY=sk_test_xxxxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxxxx

# ─── Bank APIs ────────────────────────────────────────────────────────

# Okra (Nigeria): https://okra.ng — link bank, balance, debit
# OKRA_SECRET_KEY=
# OKRA_BASE_URL=https://api.okra.ng

# OpenDX (Ghana): https://opendxgh.com — payout GHS to Ghana accounts
# OPENDX_API_KEY=
# OPENDX_BASE_URL=https://api.opendxgh.com

# M-Pesa / Safaricom (Kenya): https://developer.safaricom.co.ke
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_PASSKEY=
# MPESA_SHORTCODE=
# MPESA_SECURITY_CREDENTIAL=
# MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# Stitch (South Africa): https://stitch.money
# STITCH_CLIENT_ID=
# STITCH_CLIENT_SECRET=
# STITCH_BASE_URL=https://api.stitch.money

# Interswitch (Nigeria): https://sandbox.interswitchng.com
# INTERSWITCH_CLIENT_ID=
# INTERSWITCH_SECRET_KEY=
# INTERSWITCH_TERMINAL_ID=3OBM0001
# INTERSWITCH_BASE_URL=https://qa.interswitchng.com

# AML — ComplyAdvantage (adverse media screening)
# COMPLY_ADVANTAGE_API_KEY=

# Sentry (error tracking / monitoring)
# SENTRY_DSN=

# Base URL for callback URLs (webhooks, M-Pesa, etc.)
# API_BASE_URL=https://api.obeam.co
